# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nera_app
DB_PASSWORD=nera_app_secure
DB_DATABASE=nera_cosmetique
# Ou utilise DATABASE_URL pour une connexion unique (ex. Render)
# DATABASE_URL=postgresql://user:password@host:5432/database

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# Dev helpers (à laisser à false en production)
ENABLE_DEV_AUTH_HELPERS=false
